      "parameters": {
        "jsCode": "// 创建一个空数组来存放最终的结果\nconst newItems = [];\n\n// 这是用来提取图片URL的正则表达式\n// 只匹配 ![...] (...) 格式的 .png 图片\nconst regex = /!\\[.*?\\]\\((https?:\\/\\/[^\\)]+\\.png)\\)/g;\n\n// 遍历从上一个节点传入的所有项目\nfor (const item of items) {\n  // 从输入数据中获取 output 字符串\n  // 路径是 item.json.output，这与你提供的JSON结构一致\n  const outputText = item.json.output;\n\n  // 使用 matchAll 查找所有匹配的图片链接\n  // matchAll 返回一个迭代器，我们将其转换为数组\n  const matches = [...outputText.matchAll(regex)];\n\n  // 遍历所有找到的匹配项\n  for (const match of matches) {\n    // 我们想要的是第一个捕获组 (match[1])，即括号内的URL\n    const imageUrl = match[1];\n    \n    // 为每一个找到的 URL 创建一个新的 n8n 项目\n    // 这样，下一个节点就可以分别处理每一张图片\n    newItems.push({\n      json: {\n        imageUrl: imageUrl,\n        // (可选) 你也可以保留原始数据\n        // originalData: item.json \n      }\n    });\n  }\n}\n\n// 返回新创建的项目数组\n// n8n 会将这些项目传递给下一个节点\nreturn newItems;"
      },
