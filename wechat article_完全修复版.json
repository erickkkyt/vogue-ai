      "parameters": {
        "jsCode": "// 获取上一个节点传入的数据项\nconst item = items[0];\n\n// 1. 定义你的JSON模板。\n// 注意：为了在JS代码中直接使用，我们把它定义成一个JS对象。\n// n8n的表达式 {{ $json.field }} 在Code节点中不能直接使用，\n// 所以我们从输入项中获取这些值。\nconst template = [{\n  \"title\": $input.first().json.data.catchyTitle,\n  \"thumb_media_id\": $input.first().json.media_id,\n  \"author\": \"测试\",\n  \"digest\": $input.first().json.data.engagingSummary,\n  \"show_cover_pic\": 1,\n  \"content\": \"\", // 先留空，待会儿填充\n  \"content_source_url\": \"\",\n}];\n\n\n// 2. 获取你准备好的、纯净的HTML内容\n//    请确保上一个节点输出了一个名为 \"cleanedHtml\" 的字段\nconst htmlContent = item.json.format_html;\n\n// 3. 将HTML内容填充到模板的 content 字段中\n//    因为 template 是一个数组，我们修改第一个元素 [0]\ntemplate[0].content = htmlContent;\n\n// 4. 将最终构建好的对象作为新的输出\n//    我们创建一个新字段 \"finalArticle\" 来存放结果\n// item.json.finalArticle = template;\n\nconst content = JSON.stringify(template)\n\n\nreturn {\n  json: {\n    content: content\n  }\n};"
